---
import { ui } from "@/i18n/ui";

const { lang } = Astro.params;
const t = ui[lang || "es"];
---
<section
  id="ticketReady"
  class="flex items-center justify-center opacity-0 transition-opacity duration-1000 ease-in-out p-5 min-h-screen"
>
  <div class="max-w-2xl w-full bg-white border border-gray-100 rounded-3xl shadow-2xl overflow-hidden">
    <div class="p-8 flex flex-col items-center">
      
      <div class="mb-2 text-center">
        <div class="bg-green-100 p-3 rounded-full w-fit mx-auto mb-4">
          <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-gray-800 mb-3">
          {t["confirmed.title"]}
        </h2>
        <p class="text-gray-600 max-w-sm mx-auto">
          {t["confirmed.description"]} <span class="font-semibold text-neutral-primary-medium">{t["confirmed.description.email"]}</span> {t["confirmed.description.final"]}
        </p>
      </div>

      <div class="relative w-full h-72 flex items-center justify-center">
        <div class="absolute border border-gray-200 w-full max-w-lg h-56 bg-gray-50 rounded-2xl shadow-sm -rotate-3 z-10"></div>
        
        <div class="absolute border border-gray-300 w-full max-w-lg h-56 p-6 bg-white rounded-2xl shadow-xl z-20 flex items-center">
          <div class="grid grid-cols-3 gap-4 w-full h-full items-center">
            
            <div class="col-span-2 border-r-2 border-dashed border-gray-200 pr-4">
              <div class="flex items-center gap-4 mb-6">
                <img id="imgTour" src="" alt="" class="w-20 h-20 rounded-xl object-cover bg-gray-100" />
                <div>
                  <h2 class="text-xl font-bold text-gray-800 leading-tight" id="tour"></h2>
                </div>
              </div>
              
              <div class="grid grid-cols-2 gap-y-2 text-gray-500">
                <div class="flex items-center gap-2 text-xs">
                  <span>🕒 <span id="hour"></span></span>
                </div>
                <div class="flex gap-3 text-[10px] font-bold uppercase">
                  <span><span id="adult">2</span></span>
                  <span><span id="child">1</span></span>
                </div>
                 <div class="col-span-2 text-sm text-center">
                  <span>📅 <span id="date"></span></span>
                </div>
              </div>
            </div>

            <div class="flex justify-center items-center">
              <img id="qr" src="" alt="QR" class="w-24 h-24 md:w-32 md:h-32 object-contain" />
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-2 w-full">
        <p class="text-2xl font-bold text-gray-800 mb-6 italic">{t["confirmed.footer.title"]} </p>
      </div>
    </div>
  </div>
</section>