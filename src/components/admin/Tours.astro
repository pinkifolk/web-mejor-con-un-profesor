---

---

<article class="overflow-y-auto h-full">
  <header class="flex items-center justify-between bg-header h-16 px-11 my-4">
    <h1 class="text-4xl font-bold">Lista de tours</h1>
    <a
      href="nuevo"
      class="bg-fondo-place text-text-place text-sm py-2 px-4 rounded-4xl hover:bg-buttons hover:text-text-button"
      aria-label="Crear nuevo Tour">Crear Tour</a
    >
  </header>
  <section class="px-11 mb-10">
    <div class="border border-table rounded-lg w-full">
      <table class="min-w-full w-full table-fixed">
        <thead>
          <tr class="text-left border-b border-table font-medium text-sm">
            <th></th>
            <th class="py-2 font-normal w-1/4">Nombre</th>
            <th class="py-2 font-normal w-1/4">Estado</th>
            <th class="py-2 font-normal w-1/4">Acción</th>
          </tr>
        </thead>
        <tbody id="table-body"> </tbody>
      </table>
    </div>
  </section>
</article>
<!-- modal para eliminar -->
<div
  data-dialog-backdrop="delete"
  data-dialog-backdrop-close="true"
  class="pointer-events-none fixed inset-0 z-[999] grid h-screen w-screen place-items-center
         bg-black/60 opacity-0 transition-opacity duration-300"
>
  <div
    data-dialog="delete"
    class="relative m-4 p-4 w-2/5 min-w-[40%] max-w-[40%] rounded-lg bg-white shadow-sm"
  >
    <div
      class="flex shrink-0 items-center pb-4 text-xl font-medium text-slate-800"
    >
      Eliminar Tour
    </div>
    <form>
      <div
        class="relative border-t border-slate-200 py-4 leading-normal text-slate-600 font-light"
      >
        ¿Estás seguro de que deseas eliminar este tour? Esta acción no se puede
        deshacer.
      </div>
      <div class="flex shrink-0 flex-wrap items-center pt-4 justify-end">
        <button
          data-dialog-close="true"
          class="rounded-md border border-transparent py-2 px-4 text-center text-sm transition-all cursor-pointer text-slate-600 hover:bg-slate-100 focus:bg-slate-100 active:bg-slate-100 disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none"
          type="button"
        >
          Cancelar
        </button>
        <button
          id="delete"
          class="rounded-md bg-buttons py-2 px-4 border border-transparent text-center text-sm text-white transition-all shadow-md cursor-pointer active:shadow-none disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none ml-2"
          type="submit"
        >
          Eliminar
        </button>
      </div>
    </form>
  </div>
</div>
<!-- modal para cambiar estado -->
<div
  data-dialog-backdrop="changeStatus"
  data-dialog-backdrop-close="true"
  class="pointer-events-none fixed inset-0 z-[999] grid h-screen w-screen place-items-center
         bg-black/60 opacity-0 transition-opacity duration-300"
>
  <div
    data-dialog="changeStatus"
    class="relative m-4 p-4 w-2/5 min-w-[40%] max-w-[40%] rounded-lg bg-white shadow-sm"
  >
    <div
      class="flex shrink-0 items-center pb-4 text-xl font-medium text-slate-800"
    >
      <span id="title"></span>
    </div>
    <form>
      <div
        class="relative border-t border-slate-200 py-4 leading-normal text-slate-600 font-light"
      >
        <span id="body">activar</span>
      </div>
      <div class="flex shrink-0 flex-wrap items-center pt-4 justify-end">
        <button
          data-dialog-close="true"
          class="rounded-md border border-transparent py-2 px-4 text-center text-sm transition-all cursor-pointer text-slate-600 hover:bg-slate-100 focus:bg-slate-100 active:bg-slate-100 disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none"
          type="button"
        >
          Cancelar
        </button>
        <button
          id="change"
          class="rounded-md bg-buttons py-2 px-4 border border-transparent text-center text-sm text-white transition-all shadow-md cursor-pointer active:shadow-none disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none ml-2"
          type="submit"
        >
          Pausar
        </button>
      </div>
    </form>
  </div>
</div>
<!-- modal para ver -->
<div
  data-dialog-backdrop="showTour"
  data-dialog-backdrop-close="true"
  class="pointer-events-none fixed inset-0 z-[999] grid h-screen w-screen place-items-center
         bg-black/60 opacity-0 transition-opacity duration-300"
>
  <div
    data-dialog="showTour"
    class="relative m-4 p-4 w-4xl rounded-lg bg-white shadow-sm"
  >
    <div
      class="flex shrink-0 items-center pb-4 text-xl font-medium text-slate-800"
    >
      <span id="titleShowModal"></span>
    </div>
    <div
      class="relative border-t border-slate-200 py-4 leading-normal text-slate-600 font-light"
    >
      <div id="bodyShowDetail" class="p-4 max-h-96 overflow-y-auto"></div>
    </div>
    <div class="flex shrink-0 flex-wrap items-center pt-4 justify-end">
      <button
        data-dialog-close="true"
        class="rounded-md bg-buttons py-2 px-4 border border-transparent text-center text-sm text-white transition-all shadow-md cursor-pointer active:shadow-none disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none ml-2"
        type="button"
      >
        Aceptar
      </button>
    </div>
  </div>
</div>
<script>
  import { actions } from "astro:actions";
  import type { TourAdmin } from "../../types/tours.js";
  import { Notyf } from "notyf";
  const notyf = new Notyf({
    duration: 3000,
    position: { x: "center", y: "bottom" },
    types: [
      {
        type: "custom-success",
        background: "#16a34a",
        icon: {
          className: "notyf__icon-custom",
          tagName: "div",
        },
      },
      {
        type: "custom-error",
        background: "#dc2626",
        icon: {
          className: "notyf__icon-custom2",
          tagName: "div",
        },
      },
    ],
  });
  let id: string | null = null;
  let status: string | null = null;
  const tableBody = document.getElementById("table-body");
  const forms = document.querySelectorAll("form");
  const title = document.getElementById("title") as HTMLElement;
  const titleShowModal = document.getElementById(
    "titleShowModal",
  ) as HTMLElement;
  const body = document.getElementById("body") as HTMLElement;
  const btnChange = document.getElementById("change") as HTMLButtonElement;

  async function getData() {
    try {
      const { data, error } = await actions.tours.read();
      if (data) {
        if (tableBody) {
          tableBody.innerHTML = "";
          data.forEach((tour: TourAdmin) => {
            const row = document.createElement("tr");
            row.className =
              "hover:bg-fondo text-text text-sm border-b border-table last:border-b-0";
            row.innerHTML = `
              <td class="pl-4 py-4">
                <img class="w-28 h-28 rounded-2xl" src="${tour.img}" alt="">
              </td>
              <td class="pl-4 py-4">${tour.name_es}</td>
              <td>
                <span class="bg-fondo-place rounded-3xl px-8 py-2">
                  ${!tour.status ? "Activo" : "Pausado"}
                </span>
              </td>
              <td>
                <a href="${tour.id}"
                  data-id="${tour.id}"
                  class="text-text-place font-semibold cursor-pointer border-r border-table px-2 inline-block"
                  >
                  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M200-200h57l391-391-57-57-391 391v57Zm-80 80v-170l528-527q12-11 26.5-17t30.5-6q16 0 31 6t26 18l55 56q12 11 17.5 26t5.5 30q0 16-5.5 30.5T817-647L290-120H120Zm640-584-56-56 56 56Zm-141 85-28-29 57 57-29-28Z"/></svg>
                </a>
                <button  
                  type="button" 
                  data-id="${tour.id}"
                  data-status="${tour.status}"
                  class="text-text-place font-semibold cursor-pointer border-r border-table px-2" 
                  data-dialog-target="changeStatus"
                  >${!tour.status ? '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M520-200v-560h240v560H520Zm-320 0v-560h240v560H200Zm400-80h80v-400h-80v400Zm-320 0h80v-400h-80v400Zm0-400v400-400Zm320 0v400-400Z"/></svg>' : '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M320-200v-560l440 280-440 280Zm80-280Zm0 134 210-134-210-134v268Z"/></svg>'}
                </button>
                <button  
                  data-id="${tour.id}"  
                  type="button" 
                  class="text-text-place font-semibold cursor-pointer border-r border-table px-2"
                  data-dialog-target="showTour"
                  >
                  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M607.5-372.5Q660-425 660-500t-52.5-127.5Q555-680 480-680t-127.5 52.5Q300-575 300-500t52.5 127.5Q405-320 480-320t127.5-52.5Zm-204-51Q372-455 372-500t31.5-76.5Q435-608 480-608t76.5 31.5Q588-545 588-500t-31.5 76.5Q525-392 480-392t-76.5-31.5ZM214-281.5Q94-363 40-500q54-137 174-218.5T480-800q146 0 266 81.5T920-500q-54 137-174 218.5T480-200q-146 0-266-81.5ZM480-500Zm207.5 160.5Q782-399 832-500q-50-101-144.5-160.5T480-720q-113 0-207.5 59.5T128-500q50 101 144.5 160.5T480-280q113 0 207.5-59.5Z"/></svg>
                </button>
                <button
                  type="button"
                  data-id="${tour.id}"
                  class="text-text-place font-semibold cursor-pointer px-2"
                  data-dialog-target="delete"
                >
                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="currentColor"><path d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z"/></svg>
                </button>
              </td>
            `;
            tableBody.appendChild(row);
          });
          attachDialogListeners();
        }
      } else {
        notyf.open({
          type: "custom-error",
          message: "Error al obtener los datos",
        });
      }
    } catch (error) {
      console.error("Error al obtener los datos:", error);
    }
  }
  getData();
  async function showDetails(id: string) {
    const bodyShowContent = document.getElementById(
      "bodyShowDetail",
    ) as HTMLImageElement;
    try {
      const {data, error} = await actions.tours.readById({id});
      if (data) {
        const tour = data as TourAdmin;

        if (bodyShowContent) {
          bodyShowContent.scrollTop = 0;
          titleShowModal.textContent = tour.name;
          bodyShowContent.innerHTML = `
          <img src="${`${tour.img}`}" alt="Imagen del tour ${tour.name}" class="mb-4 w-full h-48 object-cover rounded-lg"/>
          <p class="mb-4">${tour.description}</p>
          <h3 class="font-semibold mb-2">Puntos de interés:</h3>
          <ul class="list-disc list-inside mb-4">
            ${tour.itinerary.map((point: string) => `<li>${point}</li>`).join("")}
          </ul>
          <h3 class="font-semibold mb-2">Horarios:</h3>
          <ul class="list-disc list-inside">
            ${tour.hours.map((schedule: string) => `<li>${schedule}</li>`).join("")}
          </ul>
        `;
        }
      } else {
        bodyShowContent.textContent = "Error al cargar los detalles del tour.";
      }
    } catch (error) {
      console.error("Error al obtener los detalles del tour:", error);
      bodyShowContent.textContent = "Error al cargar los detalles del tour.";
    }
  }

  function attachDialogListeners() {
    document.querySelectorAll("[data-dialog-target]").forEach((trigger) => {
      const dialogId = trigger.getAttribute("data-dialog-target");
      const dialog = document.querySelector(`[data-dialog="${dialogId}"]`);
      const backdrop = document.querySelector(
        `[data-dialog-backdrop="${dialogId}"]`,
      );

      function openDialog() {
        dialog?.classList.remove("pointer-events-none", "opacity-0");
        backdrop?.classList.remove("pointer-events-none", "opacity-0");
        id = trigger.getAttribute("data-id") || "";
        status = trigger.getAttribute("data-status") || "false";

        if (dialogId === "changeStatus") {
          title.textContent = `${
            status === "false" ? "Pausar el Tour" : "Activar el Tour"
          }`;
          body.textContent = `${
            status === "false"
              ? "¿Estás seguro de que deseas Pausar este tour? Los usuarios no podrán reservarlo hasta que se reactive."
              : "¿Estás seguro de que deseas Activar este tour?"
          }`;
          btnChange.textContent = `${
            status === "false" ? "Pausar" : "Activar"
          }`;
        }
        if (dialogId === "showTour") {
          showDetails(id);
        }
      }

      function closeDialog() {
        dialog?.classList.add("pointer-events-none", "opacity-0");
        backdrop?.classList.add("pointer-events-none", "opacity-0");
        id = null;
        status = null;
      }

      trigger.addEventListener("click", openDialog);
      dialog
        ?.querySelectorAll("[data-dialog-close]")
        .forEach((closeBtn) => closeBtn.addEventListener("click", closeDialog));
      backdrop?.addEventListener("click", (event) => {
        if (
          event.target === backdrop &&
          backdrop.hasAttribute("data-dialog-backdrop-close")
        ) {
          closeDialog();
        }
      });
    });
  }
  forms.forEach((form) =>
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const buttonSubmit = event.submitter as HTMLButtonElement;
      buttonSubmit.disabled = true;

      async function actionsModel(action: string) {
        if (!id) {
          throw new Error("ID no disponible");
        }
        switch (action) {
          case "change":
            return await actions.tours.changeStatus({id, status: status === "false" ? true : false});
          case "delete":
            return await actions.tours.delete({id});
          default:
            throw new Error("Acción no reconocida");
        }
      }
      const response = await actionsModel(buttonSubmit.id);
      if (response.error) {
        const zodError = response.error.issues?.[0]?.message;
        const errorMessage = zodError || response.error.message || "Error desconocido";
        notyf.open({
          type: "custom-error",
          message: errorMessage,
        });
      } else {
        notyf.open({
          type: "custom-success",
          message: `Tour ${buttonSubmit.id === "change" ? `${status === "false" ? "pausado" : "activado"}` : buttonSubmit.id === "delete" ? "eliminado" : "creado"} exitosamente`,
        });
        getData();
        document
          .querySelectorAll<HTMLElement>("[data-dialog-close]")
          .forEach((btn) => btn.click());
      }
      buttonSubmit.disabled = false;

    }),
  );
</script>
