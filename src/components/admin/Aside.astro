---
import HomeIcons from "@/assets/home.svg";
import ToursIcons from "@/assets/tours.svg";
import ConfigIcons from "@/assets/config.svg";
import Chevron from "@/assets/chevron.svg";
import Users from "@/assets/user.svg";
import Language from "@/assets/language.svg";
---

<aside class="w-64 text-black p-4 shadow-lg">
  <h2 class="text-lg font-bold mb-6">Panel</h2>
  <nav class="flex flex-col gap-2">
    <a
      href="dashboard"
      class="flex items-center gap-4 hover:bg-fondo-place py-2 px-4 rounded-3xl"
    >
      <HomeIcons />
      <span>Dashboard</span>
    </a>

    <a
      href="tours"
      class="flex items-center gap-4 hover:bg-fondo-place py-2 px-4 rounded-3xl"
    >
      <ToursIcons />
      <span>Tours</span>
    </a>
    <a
      href="#"
      class="flex items-center gap-4 hover:bg-fondo-place py-2 px-4 rounded-3xl"
    >
      <ConfigIcons />
      <span>Configuración</span>
      <Chevron class="ml-auto transition-transform duration-200" />
    </a>
    <ul id="submenu-config" class="bg-white ml-5">
      <a
        href="idiomas"
        class="flex items-center gap-4 hover:bg-fondo-place py-2 px-4 rounded-3xl"
      >
        <Language />
        <span>Idiomas</span>
      </a>
      <a
        href="usuario"
        class="flex items-center gap-4 hover:bg-fondo-place py-2 px-4 rounded-3xl"
      >
        <Users />
        <span>Usuario</span>
      </a>
    </ul>
  </nav>
</aside>
