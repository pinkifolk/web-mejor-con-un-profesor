---
import Steps from "@/components/admin/Steps.astro";
import ElementSteps from "@/components/admin/StepsElement.astro";
import Schedule from "@/components/admin/Schedule.astro";
---

<section class="mb-10 flex">
  <Steps />
  <ElementSteps />
</section>
<Schedule />

<script>
  import Sortable from "sortablejs";
  import { Notyf } from "notyf";

  const notyf = new Notyf({
    duration: 3000,
    position: { x: "center", y: "bottom" },
  });

  const ul = document.getElementById("edit-config");
  const globalButtons = document.querySelectorAll(".lang-btn");
  if (ul) {
    ul.addEventListener("click", (e) => {
      const target = (e.target as HTMLElement).closest("[data-option]");
      if (!target) return;
      const allOptions = ul.querySelectorAll("[data-option]");
      allOptions.forEach((li) => {
        li.classList.remove("bg-fondo-place", "border-text-place");
        li.classList.add("border-gray-300");
      });
      target.classList.add("bg-fondo-place", "border-text-place");
      target.classList.remove("border-gray-300");
      const option = target.getAttribute("data-option");
      if (option) {
        showInputs(option);
      }
    });
  }
  function showInputs(option: string) {
    const divs = document.getElementsByClassName("element-panel");
    const element = document.getElementById(`element${option}`);
    for (const panel of divs) {
      panel.classList.add("opacity-0", "invisible");
      panel.classList.remove("opacity-100", "visible");
    }
    if (element) {
      element.classList.remove("invisible");
      element.classList.add("visible");
      setTimeout(() => {
        element.classList.remove("opacity-0");
        element.classList.add("opacity-100");
      }, 10);
    }
  }
  function createTag(text:string, listId:string) {
    const tag = document.createElement("span");
    tag.className =
      "flex justify-between bg-fondo-place px-8 py-4 rounded-lg text-sm animate-in fade-in cursor-pointer hover:shadow-md hover:shadow-gray-200";
    tag.innerHTML = `${text} <button type="button" class="hover:text-red-500 font-bold"><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000000"><path d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z"/></svg></button>`;
    tag.querySelector("button")?.addEventListener("click",() =>tag.remove());
    document.getElementById(listId)?.appendChild(tag);
  }
  globalButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const selectedLang = btn.getAttribute("data-lang");
      if (selectedLang) {
        document.querySelectorAll(".lang-content").forEach((content) => {
          content.classList.toggle(
            "hidden",
            !content.classList.contains(selectedLang),
          );
        });
      document.querySelector('.magic')?.classList.add('opacity-0')
      if(selectedLang !== 'es'){
        document.querySelector('.magic')?.classList.remove('opacity-0')
      }
      }

      globalButtons.forEach((b) => {
        const isActive = b.getAttribute("data-lang") === selectedLang;
        if (isActive) {
          b.classList.remove("border-gray-300");
          b.classList.add("border-text-place");
          b.classList.add("bg-fondo-place");
        } else {
          b.classList.remove("border-text-place");
          b.classList.remove("bg-fondo-place");
          b.classList.add("border-gray-300");
        }
      });
    });
  });
  document.querySelectorAll("[data-dialog-target]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-dialog-target");
      document
        .querySelector(`[data-dialog-backdrop="${id}"]`)
        ?.classList.remove("opacity-0", "pointer-events-none");
    });
  });
  document.querySelectorAll("[data-dialog-close]").forEach((btn) => {
    btn.addEventListener("click", () => {
      document
        .querySelectorAll("[data-dialog-backdrop]")
        .forEach((b) => b.classList.add("opacity-0", "pointer-events-none"));
    });
  });
  document.getElementById("addPoint")?.addEventListener("click", () => {
    const input = document.getElementById("titlePoint") as HTMLInputElement;
    if (input.value.trim()) {
      createTag(input.value.trim(), "pointsList");
      input.value = "";
    }
  });
  document.getElementById("titlePoint")?.addEventListener("keypress", (e) =>{
    const input = document.getElementById("titlePoint") as HTMLInputElement;
    if (e.key === "Enter" && input.value.trim()) {
      e.preventDefault();
      createTag(input.value.trim(), "pointsList");
      input.value = "";
    }
  });
  if (document.getElementById("pointsList"))
    Sortable.create(document.getElementById("pointsList"), { animation: 150 });
  
</script>
