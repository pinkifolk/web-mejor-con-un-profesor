---
import "../styles/global.css";
import Header from "@/components/Header.astro";
import { ui } from "@/i18n/ui";
const { mainClass, } = Astro.props;
const { lang } = Astro.params;
const pdMain = mainClass ? mainClass : "px-5 md:px-[160px] py-6";
const t = ui[lang || "es"];
const navTranslations = {
  home: t['nav.home'],
  about: t['nav.about'],
  tours: t['nav.tours'],
  contact: t['nav.contact'],
  button : t['tour.button']
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="description"
      content={t['meta.description']}
    />
    <title>
      {t['meta.title']}
    </title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css"
    />
  </head>
  <body>
    <Header menu={navTranslations}/>
    <main class={pdMain}>
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const buttonRamdom = Array.from(
      document.querySelectorAll(".random"),
    ) as HTMLButtonElement[];
    if (!buttonRamdom) return;
    buttonRamdom.forEach((button) => {
      button.addEventListener("click", async () => {
        try {
          button.disabled = true;
          const originalContent = button.innerHTML;
          button.innerHTML = `
					<svg class="animate-spin h-5 w-5 inline-block text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
					</svg>
					`;
          const response = await fetch("/api/random-tour");
          const data = await response.json();
          if (data.response && data.response.slug) {
            setTimeout(() => {
              window.location.href = `/${data.response.slug}`;
              return;
            }, 1000);
          } else {
            console.error("Respuesta inválida del servidor");
          }
          button.disabled = false;
        } catch (error) {
          console.error("Error inesperado:", error);
        }
      });
    });
  });
</script>
